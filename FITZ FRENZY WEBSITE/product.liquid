```liquid
{% layout 'theme' %}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <!-- Product Images -->
    <div class="space-y-4">
      <div class="bg-white rounded-xl overflow-hidden shadow-md">
        <img src="{{ product.featured_image | img_url: '1000x' }}" 
             alt="{{ product.featured_image.alt }}" 
             class="w-full h-auto object-cover" 
             id="mainImage">
      </div>
      <div class="grid grid-cols-4 gap-2">
        {% for image in product.images %}
        <div class="cursor-pointer border-2 border-transparent hover:border-blue-400 rounded-lg overflow-hidden transition">
          <img src="{{ image | img_url: '200x' }}" 
               alt="{{ image.alt }}" 
               class="w-full h-24 object-cover"
               onclick="document.getElementById('mainImage').src = '{{ image | img_url: '1000x' }}'">
        </div>
        {% endfor %}
      </div>
    </div>

    <!-- Product Info -->
    <div>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">{{ product.title }}</h1>
      
      <div class="flex items-center mb-4">
        <div class="flex text-yellow-400 mr-2">
          {% render 'product-rating', product: product %}
        </div>
        <span class="text-sm text-gray-600">
          {{ product.metafields.reviews.rating_count.value | default: 0 }} reviews
        </span>
      </div>

      <div class="mb-6">
        {% if product.compare_at_price > product.price %}
        <div class="flex items-center">
          <span class="text-3xl font-bold text-gray-900 mr-3">{{ product.price | money }}</span>
          <span class="text-lg text-gray-500 line-through">{{ product.compare_at_price | money }}</span>
          <span class="ml-3 bg-red-500 text-white text-sm font-bold px-2 py-1 rounded">
            {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}% OFF
          </span>
        </div>
        {% else %}
        <span class="text-3xl font-bold text-gray-900">{{ product.price | money }}</span>
        {% endif %}
      </div>

      <div class="prose max-w-none text-gray-600 mb-6">
        {{ product.description }}
      </div>

      <form action="/cart/add" method="post" class="product-form" id="add-to-cart-form">
        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-900 mb-2">{{ option.name }}</h3>
              <div class="flex flex-wrap gap-2">
                {% for value in option.values %}
                  <input type="radio" 
                         id="Option-{{ option.name }}-{{ value }}" 
                         name="options[{{ option.name }}]" 
                         value="{{ value }}" 
                         class="hidden variant-selector"
                         {% if option.selected_value == value %}checked{% endif %}>
                  <label for="Option-{{ option.name }}-{{ value }}" 
                         class="px-4 py-2 border rounded-lg cursor-pointer hover:bg-gray-100">
                    {{ value }}
                  </label>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        {% endunless %}

        <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">
        
        <div class="mb-6">
          <label for="Quantity" class="text-sm font-medium text-gray-900 mb-2 block">Quantity</label>
          <div class="flex">
            <button type="button" class="bg-gray-200 px-4 py-2 rounded-l-lg" onclick="changeQuantity(-1)">-</button>
            <input type="number" 
                   name="quantity" 
                   id="Quantity" 
                   value="1" 
                   min="1" 
                   class="w-16 text-center border-t border-b border-gray-200">
            <button type="button" class="bg-gray-200 px-4 py-2 rounded-r-lg" onclick="changeQuantity(1)">+</button>
          </div>
        </div>

        <button type="submit" 
                name="add" 
                class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition mb-4">
          Add to Cart
        </button>

        <button type="button" 
                class="w-full bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium py-3 px-6 rounded-lg transition flex items-center justify-center"
                onclick="addToWishlist({{ product.id }})">
          <i data-feather="heart" class="mr-2"></i> Save for Later
        </button>
      </form>

      <div class="mt-8 border-t border-gray-200 pt-6">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Product Details</h3>
        <div class="grid grid-cols-2 gap-4">
          {% for metafield in product.metafields.details %}
            <div>
              <p class="text-sm text-gray-500">{{ metafield | first | replace: '_', ' ' | capitalize }}</p>
              <p class="text-sm font-medium">{{ metafield | last }}</p>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  <!-- Product Reviews -->
  <div class="mt-16" id="product-reviews">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Customer Reviews</h2>
    <div id="shopify-product-reviews" data-id="{{product.id}}">
      {{ product.metafields.spr.reviews }}
    </div>
  </div>

  <!-- Related Products -->
  {% if collection %}
  <div class="mt-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">You May Also Like</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {% for product in collection.products limit: 4 %}
        {% unless product.handle == current_product.handle %}
          <div class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition">
            <a href="{{ product.url }}">
              <img src="{{ product.featured_image | img_url: '640x360', crop: 'center' }}" alt="{{ product.title }}" class="w-full h-48 object-cover">
            </a>
            <div class="p-4">
              <h3 class="font-medium text-gray-900 mb-1">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>
              <p class="text-sm text-gray-600 mb-2">{{ product.price | money }}</p>
              <form action="/cart/add" method="post" class="product-form">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button type="submit" class="bg-blue-100 text-blue-600 p-2 rounded-full hover:bg-blue-200 transition">
                  <i data-feather="shopping-cart" class="w-4 h-4"></i>
                </button>
              </form>
            </div>
          </div>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
  {% endif %}
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  feather.replace();
  
  // Variant selection
  document.querySelectorAll('.variant-selector').forEach(radio => {
    radio.addEventListener('change', function() {
      // Find matching variant
      const selectedOptions = Array.from(document.querySelectorAll('.variant-selector:checked'))
        .map(el => el.value);
      
      const selectedVariant = product.variants.find(variant => {
        return selectedOptions.every(option => 
          variant.options.includes(option)
        );
      });
      
      if (selectedVariant) {
        document.getElementById('variant-id').value = selectedVariant.id;
        
        // Update price
        const priceElement = document.querySelector('.price');
        if (priceElement) {
          priceElement.textContent = Shopify.formatMoney(selectedVariant.price, '{{ shop.money_format }}');
        }
        
        if (selectedVariant.compare_at_price > selectedVariant.price) {
          // Show sale price
        } else {
          // Hide sale price
        }
      }
    });
  });

  function changeQuantity(amount) {
    const quantityInput = document.getElementById('Quantity');
    let newQuantity = parseInt(quantityInput.value) + amount;
    if (newQuantity < 1) newQuantity = 1;
    quantityInput.value = newQuantity;
  }
});
</script>

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
```

