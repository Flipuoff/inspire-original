    <script>
        // Initialize Vanta.js globe background
        VANTA.GLOBE({
            el: "#vanta-globe",
            mouseControls: true,
            touchControls: true,
            gyroControls: false,
            minHeight: 200.00,
            minWidth: 200.00,
            scale: 1.00,
            scaleMobile: 1.00,
            color: 0x3b82f6,
            backgroundColor: 0xf8fafc,
            size: 0.8
        });

        // Spin wheel functionality
        document.addEventListener('DOMContentLoaded', () => {
            feather.replace();
            
            // Show spin popup after delay
            setTimeout(() => {
                document.getElementById('spin-popup').classList.remove('hidden');
            }, 5000);
            
            // Close spin popup
            document.getElementById('close-spin').addEventListener('click', () => {
                document.getElementById('spin-popup').classList.add('hidden');
            });
            
            // Spin wheel animation
            const spinButton = document.getElementById('spin-button');
            const wheel = document.getElementById('wheel');
            
            spinButton.addEventListener('click', () => {
                spinButton.disabled = true;
                const spins = 5 + Math.floor(Math.random() * 5); // 5-10 spins
                const degrees = spins * 360 + (Math.floor(Math.random() * 6) * 60); // Land on random section
                
                wheel.style.transition = 'transform 3s cubic-bezier(0.17, 0.67, 0.21, 0.99)';
                wheel.style.transform = `rotate(${degrees}deg)`;
                
                setTimeout(() => {
                    spinButton.disabled = false;
                    // Determine prize based on final position
                    const prizes = ['10% OFF', '15% OFF', 'Free Shipping', '5% OFF', '20% OFF', 'Try Again'];
                    const prizeIndex = Math.floor((degrees % 360) / 60);
                    alert(`Congratulations! You won: ${prizes[prizeIndex]}`);
                    document.getElementById('spin-popup').classList.add('hidden');
                }, 3000);
            });
            
            // Animate elements on scroll
            const animateOnScroll = () => {
                const elements = document.querySelectorAll('.hero-gradient, .wheel-section');
                elements.forEach(el => {
                    const elementPosition = el.getBoundingClientRect().top;
                    const screenPosition = window.innerHeight / 1.3;
                    
                    if(elementPosition < screenPosition) {
                        el.style.opacity = '1';
                        el.style.transform = 'translateY(0)';
                    }
                });
            };
            
            window.addEventListener('scroll', animateOnScroll);
            animateOnScroll(); // Initial check
        });
    </script>
