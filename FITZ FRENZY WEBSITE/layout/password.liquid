<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ shop.name }} — {{ 'general.password_page.title' | t }}</title>
    {{ content_for_header }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
      :root {
        color-scheme: light;
      }

      *, *::before, *::after {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: 'Poppins', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: radial-gradient(circle at 20% 20%, rgba(0, 212, 255, 0.16), transparent 55%),
                    radial-gradient(circle at 80% 0%, rgba(16, 63, 121, 0.28), transparent 60%),
                    #0a1423;
        color: #f7fafc;
        display: flex;
        align-items: stretch;
        justify-content: center;
        padding: 32px 16px;
      }

      .password-wrapper {
        display: grid;
        width: min(100%, 1080px);
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 32px;
        background: rgba(7, 16, 33, 0.72);
        border-radius: 32px;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.45);
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      .password-hero {
        position: relative;
        padding: 56px 48px;
        background: linear-gradient(160deg, rgba(16, 63, 121, 0.88) 0%, rgba(0, 212, 255, 0.58) 100%);
        isolation: isolate;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 48px;
      }

      .password-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background: url("{{ 'password-stars.svg' | asset_url }}") center/cover no-repeat;
        opacity: 0.2;
        z-index: -1;
      }

      .password-logo {
        font-family: 'Montserrat', sans-serif;
        font-weight: 700;
        font-size: clamp(1.75rem, 2.2vw, 2.3rem);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin: 0 0 12px;
      }

      .password-tagline {
        font-size: 0.95rem;
        margin: 0;
        line-height: 1.6;
        color: rgba(244, 250, 255, 0.85);
      }

      .password-highlight {
        display: grid;
        gap: 20px;
      }

      .password-stat {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 18px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(6px);
      }

      .password-stat span:first-child {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: rgba(247, 250, 252, 0.7);
      }

      .password-stat strong {
        font-size: clamp(1.1rem, 2.1vw, 1.6rem);
        font-weight: 700;
      }

      .password-main {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 32px;
        padding: 56px 48px;
        background: rgba(6, 13, 28, 0.85);
      }

      .password-heading {
        margin: 0;
        font-size: clamp(2rem, 3vw, 2.7rem);
        font-weight: 700;
        font-family: 'Montserrat', sans-serif;
      }

      .password-message {
        margin: 0;
        font-size: 1rem;
        line-height: 1.7;
        color: rgba(237, 242, 247, 0.75);
      }

      form.password-form {
        display: flex;
        flex-direction: column;
        gap: 20px;
        background: rgba(11, 21, 42, 0.72);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 24px;
        backdrop-filter: blur(10px);
      }

      .password-form label {
        font-size: 0.85rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(163, 174, 191, 0.85);
      }

      .password-form input[type="password"] {
        width: 100%;
        padding: 16px 18px;
        border-radius: 14px;
        border: 1px solid rgba(226, 232, 240, 0.2);
        background: rgba(17, 25, 48, 0.85);
        color: #f7fafc;
        font-size: 1rem;
        transition: border 0.2s ease, box-shadow 0.2s ease;
      }

      .password-form input[type="password"]:focus {
        outline: none;
        border-color: rgba(56, 189, 248, 0.8);
        box-shadow: 0 0 0 3px rgba(125, 211, 252, 0.25);
      }

      .password-form button[type="submit"] {
        appearance: none;
        border: none;
        border-radius: 999px;
        padding: 16px 24px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        background: linear-gradient(120deg, #38bdf8 0%, #60a5fa 100%);
        color: #0b1221;
        box-shadow: 0 12px 24px rgba(14, 165, 233, 0.35);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .password-form button[type="submit"]:hover {
        transform: translateY(-1px);
        box-shadow: 0 18px 35px rgba(14, 165, 233, 0.4);
      }

      .password-form button[type="submit"]:active {
        transform: translateY(0);
      }

      .password-form .form-errors {
        color: #fecaca;
        font-size: 0.95rem;
        line-height: 1.5;
      }

      .password-notify {
        display: flex;
        flex-direction: column;
        gap: 16px;
        background: rgba(11, 21, 42, 0.65);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 24px;
      }

      .password-notify h3 {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 600;
        font-family: 'Montserrat', sans-serif;
      }

      .password-notify p {
        margin: 0;
        color: rgba(226, 232, 240, 0.75);
        line-height: 1.6;
        font-size: 0.95rem;
      }

      .password-notify form {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .password-notify input[type="email"] {
        flex: 1;
        min-width: 220px;
        padding: 14px 16px;
        border-radius: 14px;
        border: 1px solid rgba(226, 232, 240, 0.2);
        background: rgba(17, 25, 48, 0.85);
        color: #f7fafc;
      }

      .password-notify button {
        appearance: none;
        border: none;
        border-radius: 14px;
        padding: 14px 20px;
        font-weight: 600;
        cursor: pointer;
        background: rgba(96, 165, 250, 0.15);
        color: #e0f2fe;
        transition: background 0.2s ease, transform 0.2s ease;
      }

      .password-notify button:hover {
        background: rgba(56, 189, 248, 0.35);
        transform: translateY(-1px);
      }

      footer.password-footer {
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(148, 163, 184, 0.6);
      }

      footer.password-footer a {
        color: inherit;
        text-decoration: none;
      }

      footer.password-footer a:hover {
        color: #bae6fd;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      @media (max-width: 768px) {
        body {
          padding: 24px 16px;
        }

        .password-hero,
        .password-main {
          padding: 40px 28px;
        }
      }
    </style>
  </head>
  <body>
    <div class="password-wrapper">
      <aside class="password-hero">
        <div>
          <p class="password-logo">{{ shop.name }}</p>
          <p class="password-tagline">{{ 'general.password_page.opening_soon' | t }}</p>
          {% if shop.password_message != blank %}
            <div class="password-highlight" role="status">
              <div class="password-stat">
                <span>{{ 'general.password_page.password_message' | t }}</span>
                <strong>{{ shop.password_message }}</strong>
              </div>
            </div>
          {% endif %}
        </div>
        <footer class="password-footer">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }} · <a href="mailto:{{ shop.email }}">{{ shop.email }}</a>
        </footer>
      </aside>
      <main class="password-main" role="main">
        <header>
          <h1 class="password-heading">{{ 'general.password_page.login_form_heading' | t }}</h1>
          <p class="password-message">{{ 'general.password_page.login_form_subheading' | t }}</p>
        </header>
        <section aria-labelledby="StorefrontPassword">
          {% form 'storefront_password', class: 'password-form' %}
            <label for="Password">{{ 'general.password_page.login_form_password_label' | t }}</label>
            <input id="Password" type="password" name="password" autocomplete="current-password" placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}" required>
            {% if form.errors %}
              <div class="form-errors" role="alert">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}
            <button type="submit">{{ 'general.password_page.login_form_submit' | t }}</button>
          {% endform %}
        </section>
        <section class="password-notify" aria-labelledby="PasswordNotify">
          <h3 id="PasswordNotify">{{ 'general.password_page.notify_form_heading' | t }}</h3>
          <p>{{ 'general.password_page.notify_form_subheading' | t }}</p>
          {% form 'customer', class: 'password-notify-form' %}
            <input type="hidden" name="contact[tags]" value="password page">
            <label for="PasswordEmail" class="visually-hidden">{{ 'general.password_page.notify_form_email_placeholder' | t }}</label>
            <input id="PasswordEmail" type="email" name="contact[email]" autocomplete="email" placeholder="{{ 'general.password_page.notify_form_email_placeholder' | t }}" required>
            <button type="submit">{{ 'general.password_page.notify_form_submit' | t }}</button>
            {% if form.posted_successfully? %}
              <p role="status">{{ 'general.password_page.notify_form_success' | t }}</p>
            {% elsif form.errors %}
              <div class="form-errors" role="alert">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}
          {% endform %}
        </section>
        {{ content_for_layout }}
      </main>
    </div>
  </body>
</html>
